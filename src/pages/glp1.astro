            </div>
          </article>
          <article class="plan-card">
            <p class="plan-name">ハイパワー</p>
            <p class="plan-drug">マンジャロ 12.5mg</p>
            <div class="plan-prices">
              <div><span class="plan-label">初回</span><span class="plan-price">58,000<span class="plan-unit">円</span></span></div>
              <div><span class="plan-label">継続</span><span class="plan-price">60,000<span class="plan-unit">円/月</span></span></div>
              <div><span class="plan-label">3ヶ月一括</span><span class="plan-price">167,520<span class="plan-unit">円</span></span></div>
            </div>
          </article>
          <article class="plan-card">
            <p class="plan-name">マックスドーズ</p>
            <p class="plan-drug">マンジャロ 15.0mg</p>
            <div class="plan-prices">
              <div><span class="plan-label">初回</span><span class="plan-price">65,000<span class="plan-unit">円</span></span></div>
              <div><span class="plan-label">継続</span><span class="plan-price">67,000<span class="plan-unit">円/月</span></span></div>
              <div><span class="plan-label">3ヶ月一括</span><span class="plan-price">188,100<span class="plan-unit">円</span></span></div>
            </div>
          </article>
        </div>
      </div>

      {/* Category C */}
      <div class="plan-category">
        <p class="plan-cat-label">
          <span class="plan-cat-badge">カテゴリ C</span>
          リベルサス（飲むGLP-1）注射が苦手な方に
        </p>
        <div class="plan-grid plan-grid--2">
          <article class="plan-card">
            <p class="plan-name">まず試してみたい方に</p>
            <p class="plan-drug">リベルサス 3mg</p>
