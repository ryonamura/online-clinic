    forWhom: "糖質が多い食生活の方",
  },
  {
    name: "ルセフィ（ルセオグリフロジン）",
    medClass: "SGLT2阻害薬",
    route: "毎日 内服（経口）",
    feature: "日本発のSGLT2阻害薬。糖排出で体重減少をサポート",
    forWhom: "手軽に始めたい方",
  },
