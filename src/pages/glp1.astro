---
import PageLayout from "../layouts/PageLayout.astro";
import LineCta from "../components/LineCta.astro";
import { LINE_URL } from "../data/site";

const recommended = [
  {
    icon: "fa-utensils",
    title: "食事制限では落ちにくい方",
    desc: "糖質制限やカロリー制限を試したが、思うように体重が落ちない方に。",
  },
  {
    icon: "fa-brain",
    title: "食欲のコントロールが難しい方",
    desc: "空腹感が強く、食べすぎてしまう方に。GLP-1は食欲中枢に作用して満腹感をサポートします。",
  },
  {
    icon: "fa-chart-simple",
    title: "BMI 25以上の方",
    desc: "肥満度が高い方は治療の対象となりやすいとされています。医師が適切な用量を処方します。※効果には個人差があります。",
  },
  {
    icon: "fa-rotate",
    title: "リバウンドを繰り返している方",
    desc: "何度もダイエットとリバウンドを繰り返している方に。食欲管理の継続をサポートします。",
  },
  {
    icon: "fa-person-running",
    title: "運動が続かない・苦手な方",
    desc: "食欲コントロールのサポートにより、生活習慣の改善に取り組みやすくなります。もちろん運動との併用も効果的です。",
  },
  {
    icon: "fa-house-medical",
    title: "通院せずにダイエットしたい方",
    desc: "忙しくて通院できない方も、オンライン完結で医師のサポートを受けられます。",
  },
];

const medications = [
  {
    name: "マンジャロ（チルゼパチド）",
    medClass: "GIP/GLP-1受容体作動薬",
    route: "週1回 皮下注射",
    feature: "GIPとGLP-1の二重作用で食欲抑制・体重減少をサポート",
    forWhom: "しっかり減量したい方",
  },
  {
    name: "リベルサス（セマグルチド）",
    medClass: "GLP-1受容体作動薬",
    route: "毎日 内服（経口）",
    feature: "注射不要の経口GLP-1薬。食欲抑制と血糖改善をサポート",
    forWhom: "注射に抵抗がある方",
  },
  {
    name: "フォシーガ（ダパグリフロジン）",
    medClass: "SGLT2阻害薬",
    route: "毎日 内服（経口）",
