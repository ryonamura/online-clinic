const compareRows = [
  { method: "食事制限", appetite: "×", continuity: "△", supervision: "×", rebound: "高い" },
  { method: "運動", appetite: "×", continuity: "△", supervision: "×", rebound: "中程度" },
  { method: "サプリメント", appetite: "△", continuity: "○", supervision: "×", rebound: "高い" },
  { method: "GLP-1治療", appetite: "◎", continuity: "◎", supervision: "◎", rebound: "低い※", highlight: true },
];

const howItWorks = [
  {
    icon: "fa-brain",
    title: "食欲を抑える",
    desc: "脳の満腹中枢に直接作用し、食欲を自然に抑制。食べ過ぎを防ぎ、無理なくカロリーコントロールが可能になります。",
  },
  {
    icon: "fa-chart-line",
    title: "血糖値を安定させる",
    desc: "インスリン分泌を促進し、食後の血糖値上昇を緩やかにします。血糖値の安定が、脂肪の蓄積を抑えることにつながります。",
  },
  {
    icon: "fa-clock",
    title: "胃の動きを穏やかに",
    desc: "胃の動きを穏やかにし、食事の消化吸収を緩やかにします。少量の食事でも満足感が持続し、自然なカロリー制限につながります。",
  },
];

const cautions = [
  "本治療は自由診療（保険適用外）です。費用は全額自己負担となります。",
  "効果には個人差があり、すべての方に同様の効果を保証するものではありません。",
  "GLP-1受容体作動薬の主な副作用: 吐き気・嘔吐・下痢・便秘・腹痛・食欲減退などの消化器症状（使用初期に出やすく、時間とともに軽減することが多いです）。まれに低血糖・急性膵炎・胆嚢炎などの重篤な副作用が報告されています。",
  "SGLT2阻害薬（フォシーガ・ルセフィ）の主な副作用: 尿路感染症・性器感染症・頻尿・口渇・脱水など。十分な水分補給をお願いします。",
  "医師のオンライン診察が必要です。問診内容により処方できない場合があります。",
];

const contraindications = [
  "妊娠中・授乳中の方",
  "膵炎の既往がある方",
  "甲状腺髄様がん・MEN2の既往または家族歴がある方",
  "重度の腎機能障害・透析中の方",
  "1型糖尿病の方",
];
---

<PageLayout
  title="GLP-1ダイエット（メディカルダイエット）のオンライン診療｜キレイレポオンライン"
  description="マンジャロ・リベルサスなどGLP-1・SGLT2阻害薬を医師が処方。食欲コントロールをサポートする医療ダイエットをオンラインで。診察・配送料2,000円・定期縛りなし。"
>
  {/* ============ HERO ============ */}
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-copy">
        <p class="eyebrow">医師監修 · GLP-1オンライン処方</p>
        <h1 class="hero-title">
          GLP-1メディカルダイエットの<br />
          <span class="hero-accent">オンライン診療</span>
        </h1>
        <p class="hero-lead">
          食欲を抑え、体重管理をサポートする医療ダイエット。医師がオンラインで診察し、お薬が自宅に届きます。
        </p>
        <ul class="hero-badges">
          <li><i class="fa-solid fa-circle-check" aria-hidden="true"></i>診察・配送料 2,000円</li>
          <li><i class="fa-solid fa-circle-check" aria-hidden="true"></i>定期縛りなし</li>
          <li><i class="fa-solid fa-circle-check" aria-hidden="true"></i>オンライン完結</li>
        </ul>
        <div class="hero-actions">
          <a class="btn btn--line hero-btn" href={LINE_URL} target="_blank" rel="noopener">
            <i class="fa-brands fa-line" aria-hidden="true"></i>LINEで無料相談
          </a>
          <a class="btn btn--ghost" href="#plans">料金プランを見る</a>
        </div>
      </div>

      <div class="hero-visual" aria-hidden="true">
        <div class="hero-card hero-card--1">
          <span class="hero-card-icon"><i class="fa-solid fa-syringe"></i></span>
          <p class="hero-card-title">マンジャロ（注射）</p>
          <p class="hero-card-sub">GIP/GLP-1二重作動薬 週1回</p>
        </div>
        <div class="hero-card hero-card--2">
          <span class="hero-card-icon"><i class="fa-solid fa-pills"></i></span>
          <p class="hero-card-title">リベルサス（内服）</p>
          <p class="hero-card-sub">注射なしの経口GLP-1薬</p>
        </div>
        <div class="hero-stat">
          <div>
            <strong>7,500<span>円〜</span></strong>
            <small>月々の薬剤費</small>
          </div>
          <div class="hero-stat-div"></div>
          <div>
            <strong>0<span>回</span></strong>
            <small>通院回数</small>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ============ RECOMMENDED ============ */}
  <section class="section section--cream" id="recommended">
    <div class="container">
      <header class="section-head">
        <p class="eyebrow">RECOMMENDED</p>
        <h2 class="section-title">こんな方に<span class="accent">おすすめ</span></h2>
        <p class="lead">以下のようなお悩みをお持ちの方は、オンライン診療でご相談ください。</p>
      </header>
      <div class="rec-grid">
        {recommended.map((r) => (
          <article class="rec-card">
            <span class="rec-icon"><i class={`fa-solid ${r.icon}`} aria-hidden="true"></i></span>
            <div>
              <h3 class="rec-title">{r.title}</h3>
              <p class="rec-desc">{r.desc}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* ============ ABOUT TREATMENT ============ */}
  <section class="section" id="about">
    <div class="container">
      <header class="section-head">
        <p class="eyebrow">ABOUT</p>
        <h2 class="section-title">治療に<span class="accent">ついて</span></h2>
        <p class="lead">ダイエットの基本原則と、GLP-1治療の位置づけについてご説明します。</p>
      </header>

      <div class="formula-block">
        <p class="formula-label">ダイエットの基本原則</p>
        <p class="formula">
          <span class="formula-item">摂取カロリー</span>
          <span class="formula-op">&lt;</span>
          <span class="formula-item formula-item--accent">消費カロリー</span>
        </p>
        <p class="formula-desc">
          GLP-1は食欲を自然に抑えることで、この状態を無理なく維持しやすくする働きがあると考えられています。
        </p>
      </div>

      <h3 class="subsection-title">他の減量方法との比較</h3>
      <div class="compare-wrap">
        <table class="compare-table">
          <thead>
            <tr>
              <th>方法</th>
              <th>食欲抑制</th>
              <th>継続しやすさ</th>
              <th>医師の監修</th>
              <th>リバウンドリスク</th>
            </tr>
          </thead>
          <tbody>
            {compareRows.map((r) => (
              <tr class:list={[{ "row--highlight": r.highlight }]}>
                <td class="method-name">{r.method}</td>
                <td class:list={["cell-center", { "val--good": r.appetite === "◎" }]}>{r.appetite}</td>
                <td class:list={["cell-center", { "val--good": r.continuity === "◎" }]}>{r.continuity}</td>
                <td class:list={["cell-center", { "val--good": r.supervision === "◎" }]}>{r.supervision}</td>
                <td class:list={["cell-center", { "val--good": r.rebound === "低い※" }]}>{r.rebound}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="fineprint">※効果・リバウンドリスクには個人差があります。医師の指導のもと継続使用が推奨されます。</p>
    </div>
  </section>

  {/* ============ MEDICATIONS ============ */}
  <section class="section section--cream" id="medications">
    <div class="container">
      <header class="section-head">
        <p class="eyebrow">MEDICATIONS</p>
        <h2 class="section-title">薬の種類と<span class="accent">特徴</span></h2>
        <p class="lead">医師が診察のうえ、お体の状態やご希望に合わせた薬剤を処方します。</p>
      </header>

      <div class="med-grid">
        {medications.map((m) => (
          <article class="med-card">
            <div class="med-header">
              <p class="med-class">{m.medClass}</p>
              <h3 class="med-name">{m.name}</h3>
            </div>
            <dl class="med-detail">
              <div>
                <dt>投与方法</dt>
                <dd>{m.route}</dd>
              </div>
              <div>
                <dt>特徴</dt>
                <dd>{m.feature}</dd>
              </div>
              <div>
                <dt>こんな方に</dt>
                <dd>{m.forWhom}</dd>
              </div>
            </dl>
          </article>
        ))}
      </div>
      <p class="fineprint">
        ※いずれも国内では肥満治療目的での使用は承認適応外です。医師の判断のもと処方されます。
        ※効果には個人差があります。
      </p>
    </div>
  </section>

  {/* ============ PLANS ============ */}
  <section class="section" id="plans">
    <div class="container">
      <header class="section-head">
        <p class="eyebrow">PLANS</p>
        <h2 class="section-title">料金<span class="accent">プラン</span></h2>
        <p class="lead">すべて税込・別途診察・配送料2,000円・定期縛りなし。</p>
      </header>

      {/* Category A */}
      <div class="plan-category">
        <p class="plan-cat-label">
          <span class="plan-cat-badge">カテゴリ A</span>
          マンジャロ（注射）GIP/GLP-1受容体作動薬
        </p>
        <div class="plan-grid">
          <article class="plan-card">
            <p class="plan-name">スタートプラン</p>
            <p class="plan-drug">マンジャロ 2.5mg</p>
            <div class="plan-prices">
              <div><span class="plan-label">初回</span><span class="plan-price">12,000<span class="plan-unit">円</span></span></div>
              <div><span class="plan-label">継続</span><span class="plan-price">13,000<span class="plan-unit">円/月</span></span></div>
              <div><span class="plan-label">3ヶ月一括</span><span class="plan-price">33,900<span class="plan-unit">円</span></span></div>
              <div><span class="plan-label">6ヶ月一括</span><span class="plan-price">66,000<span class="plan-unit">円</span></span></div>
            </div>
          </article>
          <article class="plan-card plan-card--featured">
            <p class="plan-badge">よくご選択いただいています</p>
            <p class="plan-name">マンジャロ 5.0mgプラン</p>
            <p class="plan-drug">マンジャロ 5.0mg</p>
            <div class="plan-prices">
              <div><span class="plan-label">初回</span><span class="plan-price">25,000<span class="plan-unit">円</span></span></div>
              <div><span class="plan-label">継続</span><span class="plan-price">27,000<span class="plan-unit">円/月</span></span></div>
              <div><span class="plan-label">3ヶ月一括</span><span class="plan-price">74,000<span class="plan-unit">円</span></span></div>
              <div><span class="plan-label">6ヶ月一括</span><span class="plan-price">135,000<span class="plan-unit">円</span></span></div>
            </div>
          </article>
          <article class="plan-card">
            <p class="plan-name">ハイドーズプラン</p>
            <p class="plan-drug">マンジャロ 7.5mg</p>
            <div class="plan-prices">
              <div><span class="plan-label">初回</span><span class="plan-price">36,000<span class="plan-unit">円</span></span></div>
