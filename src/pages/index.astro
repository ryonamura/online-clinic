---
import PageLayout from "../layouts/PageLayout.astro";
import LineCta from "../components/LineCta.astro";
import { LINE_URL, services, shopLink } from "../data/site";
import { withBase } from "../lib/links";

const badges = [
  { icon: "fa-truck-fast", label: "最短翌日お届け", desc: "処方確定後に即発送。忙しい方も待たずに受け取れます。" },
  { icon: "fa-yen-sign", label: "わかりやすい定額", desc: "診察・配送料は 2,000円（税込）一律。追加の隠れ費用はありません。" },
  { icon: "fa-comment-dots", label: "LINEで完結・縛りなし", desc: "予約〜診察〜処方〜発送まですべてLINEで。定期縛りなしでいつでも解約可。" },
];

const serviceCards = [
  {
    slug: "glp1",
    icon: "fa-pills",
    name: "GLP-1ダイエット",
    desc: "注射薬・リベルサスなどを医師の診察のもと処方。食欲のコントロールをサポートし、無理のない医療ダイエットをご提案します。",
    price: "月々 7,500円〜",
    href: "/glp1",
    tone: "pink",
  },
  {
    slug: "beauty",
    icon: "fa-wand-magic-sparkles",
    name: "美容内服",
    desc: "ビタミンC・トラネキサム酸・L-システインなど、美白・エイジングケアの内服薬を医師が処方。内側からの肌ケアを。",
    price: "月々 2,980円〜",
    href: "/beauty",
    tone: "pink",
  },
  {
    slug: "antiaging",
    icon: "fa-dna",
    name: "アンチエイジング",
    desc: "メトホルミンによるエイジングケアアプローチ。世界的に研究が進む抗老化の選択肢を、オンライン診療で。",
    price: "月々 2,980円〜",
    href: "/antiaging",
    tone: "gold",
  },
  {
    slug: "aga",
    icon: "fa-mars",
    name: "AGA治療",
    desc: "デュタステリド0.5mg等を医師が処方。男性の薄毛（AGA）の進行抑制・発毛をサポートします。",
    price: "月々 3,480円〜",
    href: "/aga",
    tone: "navy",
  },
];

const reasons = [
  {
    icon: "fa-user-doctor",
    title: "医師によるオンライン診療",
    desc: "提携医療機関（マーチクリニック）の医師がビデオ通話で丁寧に診察。自宅にいながら医療機関の処方を受けられます。",
    tag: "診察・配送料 2,000円",
  },
  {
    icon: "fa-truck-fast",
    title: "自宅に直接お届け",
    desc: "処方されたお薬はプライバシーに配慮した梱包でお届け。定期便なら毎月自動発送で飲み忘れを防ぎます。",
    tag: "配送料込み",
  },
  {
    icon: "fa-comments",
    title: "LINEで気軽に相談",
    desc: "ご予約からお薬の変更まで、すべてLINEで完結。費用やプランのご不安も、お気軽にご相談ください。",
    tag: "相談無料",
  },
];

const steps = [
  { no: "01", title: "LINE友だち追加", time: "約30秒", desc: "ボタンまたはQRコードから友だち追加。24時間いつでも登録いただけます。" },
  { no: "02", title: "問診票を記入", time: "約5分", desc: "簡単な質問に回答するだけ。健康状態やお悩みをLINE上で入力します。" },
  { no: "03", title: "オンライン診察", time: "約10分", desc: "ビデオ通話で医師が診察し、お一人おひとりに合った処方をご提案します。" },
  { no: "04", title: "お薬が自宅に届く", time: "最短翌日発送", desc: "処方確定後にお薬を発送。定期便なら毎月自動でお届け、LINEで経過のフォローも。" },
];

const aboutPoints = [
  { icon: "fa-mobile-screen", title: "スマホで完結", desc: "ご予約・問診・診察・お支払いまで、すべてスマホ上で。通院や待ち時間は不要です。" },
  { icon: "fa-hospital", title: "医療機関による処方", desc: "提携医療機関（マーチクリニック）の医師が診察。医療機関による処方です。" },
  { icon: "fa-house-medical", title: "ご自宅にお届け", desc: "処方されたお薬はプライバシーに配慮した梱包で、最短翌日にご自宅へお届けします。" },
];

const compare = [
  { old: "予約・通院で半日つぶれる", neo: "スマホで約10分" },
  { old: "待合室での待ち時間", neo: "待ち時間ゼロ" },
  { old: "定期的に通院が必要", neo: "定期便で自動お届け" },
  { old: "薬局での受け取り", neo: "お薬が自宅に届く" },
  { old: "人目が気になる", neo: "プライバシー配慮の梱包" },
];
---

<PageLayout>
  {/* ============ HERO（CLINIC FOR風・左右分割＋訴求バッジ） ============ */}
  <section class="ha-hero">
    <div class="container ha-hero-inner">
      <div class="ha-copy">
        <p class="ha-eyebrow">
          <i class="fa-solid fa-circle-check" aria-hidden="true"></i>
          ONLINE CLINIC &nbsp;·&nbsp; 完全オンライン診療
        </p>
        <h1 class="ha-title">
          自宅にいながら<br />
          医師の診察・<span class="ha-title-accent">お薬お届け</span>
        </h1>
        <p class="ha-lead">
          GLP-1ダイエット・美容内服・アンチエイジング・AGA治療をオンラインで。<br class="ha-br-md" />
          提携医療機関（マーチクリニック）の医師がビデオ通話で診察し、<br class="ha-br-md" />
          処方薬が自宅に届きます。
        </p>
        <div class="ha-actions">
          <a class="btn btn--line ha-btn-line" href={LINE_URL} target="_blank" rel="noopener">
            <i class="fa-brands fa-line" aria-hidden="true"></i>LINEで無料相談
          </a>
          <a class="btn btn--ghost" href="#services">サービスを見る</a>
        </div>
        <ul class="ha-checklist" aria-label="主なポイント">
          <li><i class="fa-solid fa-circle-check" aria-hidden="true"></i>診察・配送料 2,000円（税込）一律</li>
          <li><i class="fa-solid fa-circle-check" aria-hidden="true"></i>定期縛りなし・いつでも解約可</li>
          <li><i class="fa-solid fa-circle-check" aria-hidden="true"></i>通院不要・オンライン完結</li>
        </ul>
      </div>

      <aside class="ha-panel" aria-label="サービスの特長">
        {badges.map((b) => (
          <div class="ha-badge">
            <span class="ha-badge-icon" aria-hidden="true"><i class={`fa-solid ${b.icon}`}></i></span>
            <div class="ha-badge-body">
              <p class="ha-badge-label">{b.label}</p>
              <p class="ha-badge-desc">{b.desc}</p>
            </div>
          </div>
        ))}
      </aside>
    </div>
  </section>

  {/* ============ SERVICES ============ */}
  <section class="section" id="services">
    <div class="container">
      <header class="section-head">
        <p class="eyebrow">SERVICES</p>
        <h2 class="section-title">診療<span class="accent">メニュー</span></h2>
        <p class="lead">目的に合わせた治療プランを医師がご提案します。すべてオンラインで完結。</p>
      </header>

      <div class="service-grid">
        {serviceCards.map((s) => (
          <a class:list={["service-card", `tone-${s.tone}`]} href={withBase(s.href)}>
            <span class="service-icon"><i class={`fa-solid ${s.icon}`}></i></span>
            <h3 class="service-name">{s.name}</h3>
            <p class="service-desc">{s.desc}</p>
            <div class="service-foot">
              <span class="service-price">{s.price}</span>
              <span class="service-more">詳しく見る<i class="fa-solid fa-arrow-right"></i></span>
            </div>
          </a>
        ))}
      </div>
      <p class="fineprint">※価格は税込。別途、診察・配送料 2,000円（税込）。自由診療（保険適用外）です。</p>
    </div>
  </section>

  {/* ============ WHY US ============ */}
  <section class="section section--cream">
    <div class="container">
      <header class="section-head">
        <p class="eyebrow">WHY US</p>
        <h2 class="section-title">キレイレポが<span class="accent">選ばれる理由</span></h2>
        <p class="lead">通院不要で、医師による診療を受けられます。</p>
      </header>
      <div class="reason-grid">
        {reasons.map((r) => (
          <article class="reason-card">
            <span class="reason-icon"><i class={`fa-solid ${r.icon}`}></i></span>
            <h3 class="reason-title">{r.title}</h3>
            <p class="reason-desc">{r.desc}</p>
            <span class="reason-tag">{r.tag}</span>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* ============ FLOW ============ */}
  <section class="section">
    <div class="container">
      <header class="section-head">
        <p class="eyebrow">HOW IT WORKS</p>
        <h2 class="section-title">診療の<span class="accent">流れ</span></h2>
        <p class="lead">友だち追加から最短その日のうちに診察まで進められます。</p>
      </header>
      <ol class="flow">
        {steps.map((s) => (
          <li class="flow-step">
            <span class="flow-no">{s.no}</span>
            <div class="flow-body">
              <p class="flow-title">{s.title}<span class="flow-time">{s.time}</span></p>
              <p class="flow-desc">{s.desc}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  {/* ============ ABOUT / COMPARISON ============ */}
  <section class="section section--cream">
    <div class="container">
      <header class="section-head">
        <p class="eyebrow">ABOUT</p>
        <h2 class="section-title">オンライン<span class="accent">診療とは</span></h2>
        <p class="lead">スマホ1台で医師の診察を受け、お薬が自宅に届く新しい医療のかたちです。</p>
      </header>
      <div class="about-grid">
        {aboutPoints.map((a) => (
          <article class="about-card">
            <span class="about-icon"><i class={`fa-solid ${a.icon}`}></i></span>
            <h3 class="about-title">{a.title}</h3>
            <p class="about-desc">{a.desc}</p>
          </article>
        ))}
      </div>

      <div class="compare">
        <div class="compare-col compare-old">
          <p class="compare-head">従来の通院</p>
          <ul>{compare.map((c) => <li><i class="fa-solid fa-xmark"></i>{c.old}</li>)}</ul>
        </div>
        <div class="compare-col compare-neo">
          <p class="compare-head">キレイレポオンライン</p>
          <ul>{compare.map((c) => <li><i class="fa-solid fa-check"></i>{c.neo}</li>)}</ul>
        </div>
      </div>
    </div>
  </section>

  {/* ============ PAYMENT & DELIVERY ============ */}
  <section class="section">
    <div class="container container--narrow">
      <header class="section-head">
        <p class="eyebrow">PAYMENT &amp; DELIVERY</p>
        <h2 class="section-title">お支払い・<span class="accent">定期配送</span>について</h2>
      </header>
      <dl class="info-list">
        <div><dt>お支払い方法</dt><dd>クレジットカード（VISA / Mastercard / JCB / AMEX）、Apple Pay、atone翌月払いに対応。</dd></div>
        <div><dt>配送について</dt><dd>全国一律 診察・配送料 2,000円（税込）。最短翌日発送、プライバシーに配慮した梱包でお届けします。</dd></div>
        <div><dt>定期配送</dt><dd>毎月自動発送で飲み忘れを防止。定期縛りはなく、次回発送日の1日前までにマイページからいつでも解約・休止が可能です。</dd></div>
      </dl>
      <p class="fineprint">※解約・休止の締切等の詳細は<a href={withBase("/legal/tokushoho")}>特定商取引法に基づく表記</a>をご確認ください。</p>
    </div>
  </section>

  {/* ============ MEDICAL DISCLAIMER ============ */}
  <section class="disclaimer">
    <div class="container container--narrow">
      <p class="disclaimer-title"><i class="fa-solid fa-circle-info"></i>ご利用にあたって</p>
      <p>
        本サービスは自由診療（保険適用外）です。効果・効能には個人差があり、すべての方に同様の効果を保証するものではありません。
        一部のお薬は、国内では特定の疾患の治療薬として承認されており、ダイエット・美容・エイジングケア目的での使用は承認適応外（適応外使用）となります。
        副作用やリスクについては、オンライン診察時に医師が十分にご説明します。診察の結果、処方を行えない場合があります。
      </p>
    </div>
  </section>

  {/* ============ ONLINE SHOP ============ */}
  <section class="section section--cream">
    <div class="container shop-banner">
      <div class="shop-banner-text">
        <p class="eyebrow">ONLINE SHOP</p>
        <h2 class="section-title">オンライン<span class="accent">ショップ</span></h2>
        <p class="lead" style="margin-top: 0.6rem;">サプリメント・スキンケアなどは、オンラインショップでもお求めいただけます。</p>
      </div>
      <a class="btn btn--brand shop-banner-btn" href={shopLink.href} target="_blank" rel="noopener">
        <i class="fa-solid fa-bag-shopping" aria-hidden="true"></i>ショップを見る
      </a>
    </div>
  </section>

  <LineCta />
</PageLayout>

<style>
  /* ===== HERO（CLINIC FOR風・採用案A：左右分割＋訴求バッジ） ===== */
  .ha-hero {
    background:
      radial-gradient(ellipse 70% 60% at 100% 0%, var(--brand-50) 0%, transparent 60%),
      radial-gradient(ellipse 50% 40% at 0% 100%, var(--cream-100) 0%, transparent 55%),
      #fff;
    padding-block: clamp(3rem, 8vw, 6rem);
    overflow: hidden;
  }
  .ha-hero-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }
  .ha-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.45em;
    font-size: var(--fs-eyebrow);
    font-weight: var(--fw-bold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--brand-700);
  }
  .ha-title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 1.3rem + 3.5vw, 3.2rem);
    font-weight: var(--fw-bold);
    line-height: 1.45;
    letter-spacing: 0.015em;
    color: var(--ink-700);
    margin-top: 1rem;
  }
  .ha-title-accent {
    color: var(--brand-700);
    position: relative;
    white-space: nowrap;
  }
  .ha-title-accent::after {
    content: "";
    position: absolute;
    inset-inline: 0;
    bottom: 0.06em;
    height: 0.28em;
    background: var(--brand-200);
    opacity: 0.6;
    z-index: -1;
  }
  .ha-lead {
    margin-top: 1.4rem;
    font-size: clamp(0.95rem, 0.85rem + 0.5vw, 1.1rem);
    color: var(--ink-500);
    line-height: 1.85;
    max-width: 36rem;
  }
  .ha-br-md {
    display: none;
  }
  .ha-actions {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
  }
  .ha-btn-line {
    font-size: 1.05rem;
    padding: 1em 2.2em;
  }
  .ha-checklist {
    margin-top: 1.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    font-size: 0.9rem;
    color: var(--ink-500);
    list-style: none;
    padding: 0;
  }
  .ha-checklist li {
    display: flex;
    align-items: center;
    gap: 0.5em;
  }
  .ha-checklist i {
    color: var(--brand-600);
    font-size: 0.95em;
    flex-shrink: 0;
  }
  .ha-panel {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .ha-badge {
    display: flex;
    align-items: flex-start;
    gap: 1.1rem;
    background: #fff;
    border: 1px solid var(--cream-300);
    border-radius: var(--r-lg);
    padding: 1.4rem 1.5rem;
    box-shadow: var(--shadow-md);
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }
  .ha-badge:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }
  .ha-badge-icon {
    flex-shrink: 0;
    display: inline-flex;
    width: 52px;
    height: 52px;
    align-items: center;
    justify-content: center;
    border-radius: var(--r-md);
    background: var(--brand-gradient-soft);
    color: var(--brand-700);
    font-size: 1.35rem;
  }
  .ha-badge-body {
    min-width: 0;
  }
  .ha-badge-label {
    font-weight: var(--fw-bold);
    font-size: 1rem;
    color: var(--ink-700);
    line-height: 1.3;
  }
  .ha-badge-desc {
    margin-top: 0.35rem;
    font-size: 0.86rem;
    color: var(--ink-500);
    line-height: 1.7;
  }
  @media (max-width: 599px) {
    .ha-title {
      word-break: break-word;
      overflow-wrap: anywhere;
    }
    .ha-badge {
      padding: 1.1rem 1.1rem;
    }
  }
  @media (min-width: 720px) {
    .ha-checklist {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 0.6rem 1.6rem;
    }
    .ha-br-md {
      display: block;
    }
  }
  @media (min-width: 960px) {
    .ha-hero-inner {
      grid-template-columns: 1.1fr 0.9fr;
      gap: 3.5rem;
    }
  }
  @media (min-width: 1100px) {
    .ha-hero-inner {
      grid-template-columns: 1.15fr 0.85fr;
      gap: 4rem;
    }
  }

  /* ============ 旧HERO（未使用） ============ */
  .hero {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(80% 70% at 85% 0%, var(--brand-100) 0%, transparent 55%),
      radial-gradient(70% 60% at 0% 100%, var(--pink-50) 0%, transparent 55%),
      var(--bg);
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    padding-block: clamp(2.8rem, 7vw, 5.5rem);
    align-items: center;
  }
  .hero-title {
    font-family: var(--font-serif);
    font-size: var(--fs-hero);
    font-weight: var(--fw-bold);
    line-height: 1.4;
    letter-spacing: 0.02em;
    margin-top: 1rem;
  }
  .hero-title-accent {
    color: var(--brand-700);
    position: relative;
  }
  .hero-title-accent::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0.05em;
    height: 0.32em;
    background: var(--brand-200);
    opacity: 0.55;
    z-index: -1;
  }
  .hero-lead {
    margin-top: 1.5rem;
    font-size: var(--fs-lead);
    color: var(--text-muted);
    max-width: 32rem;
  }
  .hero-actions {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
  }
  .hero-btn {
    font-size: 1.05rem;
    padding: 1.05em 2.1em;
  }
  .hero-notes {
    margin-top: 1.8rem;
    display: flex;
    flex-wrap: wrap;
    gap: 1.2rem;
    font-size: 0.9rem;
    color: var(--ink-500);
  }
  .hero-notes i {
    color: var(--brand-600);
    margin-right: 0.4em;
  }

  .hero-visual {
    display: none;
  }
  .hero-card {
    background: #fff;
    border: 1px solid var(--cream-300);
    border-radius: var(--r-lg);
    padding: 1.4rem 1.5rem;
    box-shadow: var(--shadow-md);
  }
  /* hero カードはグリッドで並べる（下のメディアクエリ参照） */
  .hero-card-icon {
    display: inline-flex;
    width: 48px;
    height: 48px;
    align-items: center;
    justify-content: center;
    border-radius: 14px;
    background: var(--brand-gradient-soft);
    color: var(--brand-800);
    font-size: 1.3rem;
    margin-bottom: 0.8rem;
  }
  .hero-card-icon.pink {
    background: var(--pink-100);
    color: var(--pink-600);
  }
  .hero-card-title {
    font-weight: var(--fw-bold);
    color: var(--ink-700);
  }
  .hero-card-sub {
    font-size: 0.82rem;
    color: var(--ink-400);
    margin-top: 0.2rem;
  }
  .hero-stat {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.4rem;
    background: var(--ink-900);
    color: #fff;
    border-radius: var(--r-lg);
    padding: 1.1rem 1.6rem;
    box-shadow: var(--shadow-md);
